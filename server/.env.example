# ─── Database ────────────────────────────────────────────────────────────────
# LEARN: Prisma reads DATABASE_URL to connect to Postgres.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://inkbase:inkbase_secret@localhost:5432/inkbase_dev"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# LEARN: We use TWO tokens:
#   ACCESS_TOKEN  → short-lived (15 min), sent with every API request
#   REFRESH_TOKEN → long-lived (7 days), used only to get a new access token
# This way, if an access token is stolen, it expires quickly.
# Use a strong random string: run `openssl rand -hex 64` to generate one.
JWT_ACCESS_SECRET="change_this_to_a_long_random_secret_string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_this_to_a_different_long_random_secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────
# Get from: https://cloudinary.com (free account)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"
